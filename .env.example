# Jiddat3D Environment Variables Example

# Server Configuration
DOMAIN=localhost
PORT=8090

# SMTP Configuration (e.g. Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_SENDER_EMAIL=hello@jiddat3d.com
SMTP_SENDER_NAME=Jiddat3D

# Admin Settings
ADMIN_EMAIL=admin@jiddat3d.com
ADMIN_PASSWORD=your_secure_password
